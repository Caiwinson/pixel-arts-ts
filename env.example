# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# ─── Top.gg ───────────────────────────────────────────────────────────────────
# API token for posting server stats (from https://top.gg/bot/<id>/webhooks)
TOPGG_TOKEN=

# Webhook secret for verifying incoming vote payloads
TOPGG_WEBHOOK=

# ─── Discord Webhook (optional) ───────────────────────────────────────────────
# A Discord webhook URL used to log newly generated canvases
WEBHOOK_URL=

# ─── Web ──────────────────────────────────────────────────────────────────────
# Public-facing base URL of the web service (no trailing slash)
DOMAIN_URL=https://pixel-arts.example.com

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pixelarts
